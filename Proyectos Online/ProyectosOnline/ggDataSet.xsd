<xs:schema id="ggDataSet" targetNamespace="http://tempuri.org/ggDataSet.xsd" xmlns:mstns="http://tempuri.org/ggDataSet.xsd" xmlns="http://tempuri.org/ggDataSet.xsd" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata" xmlns:msprop="urn:schemas-microsoft-com:xml-msprop" attributeFormDefault="qualified" elementFormDefault="qualified">
