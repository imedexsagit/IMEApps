                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="false">
                    <CommandText>SELECT        BONO, Etiqueta, Cantidad - ISNULL
                             ((SELECT        SUM(Piezas) AS Piezas
                                 FROM            (SELECT        ISNULL
                                                                                         ((SELECT        marcaCodigo
                                                                                             FROM            CS_CPP_0713.dbo.MP_CARGADEPIEZAS
                                                                                             WHERE        (id = TC_IMPORT_BONOS.id_mp_cargadepiezas)),
                                                                                         (SELECT        TOP (1) MP_CARGADEPIEZAS_1.marcaCodigo
                                                                                           FROM            CS_CPP_0713.dbo.MP_TRABAJOCONBONO INNER JOIN
                                                                                                                     CS_CPP_0713.dbo.MP_CARGADEPIEZAS AS MP_CARGADEPIEZAS_1 ON CS_CPP_0713.dbo.MP_TRABAJOCONBONO.id = MP_CARGADEPIEZAS_1.mjTrabajoConBonoId
                                                                                           WHERE        (CS_CPP_0713.dbo.MP_TRABAJOCONBONO.id = TC_IMPORT_BONOS.MjTrabajoConBonoId) AND (MP_CARGADEPIEZAS_1.marcaCantidad = TC_IMPORT_BONOS.PBUENAS_float))) 
                                                                                     AS Etiqueta, TC_IMPORT_BONOS.PBUENAS_float AS Piezas
                                                           FROM            TC_IMPORT_BONOS INNER JOIN
                                                                                     T_OPERAC ON TC_IMPORT_BONOS.CODEMP = T_OPERAC.CodEMP AND TC_IMPORT_BONOS.MAQUINA = T_OPERAC.PUESTO
                                                           WHERE        (TC_IMPORT_BONOS.CODEMP = TC_V_BONO_ETIQUETA.CODEMP) AND (TC_IMPORT_BONOS.MAQUINA &lt;&gt; '800') AND (TC_IMPORT_BONOS.ORDFAB_int = TC_V_BONO_ETIQUETA.ORDFAB) AND 
                                                                                     (T_OPERAC.OPERAC = TC_V_BONO_ETIQUETA.OPERAC) AND (TC_IMPORT_BONOS.BONO = TC_V_BONO_ETIQUETA.BONO)) AS t_aux
                                 WHERE        (Etiqueta = TC_V_BONO_ETIQUETA.Etiqueta)
                                 GROUP BY Etiqueta), 0) AS ctd_a_fichar
FROM            TC_V_BONO_ETIQUETA
WHERE        (CODEMP = @empresa) AND (TIPOREG = 'F') AND (ORDFAB = @of) AND (OPERAC = @operacion)
ORDER BY BONO, Etiqueta</CommandText>
