                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="false">
                    <CommandText>SELECT        T_ARTICULOS.CODIGO, T_ARTICULOS.DENOMINACION, T_CATEGORIAS.DENOMI AS Categoria, T_FAMILIAS.DENOMI AS Familia, T_ARTICULOS.FAMILIA AS idFamilia, T_ARTICULOS.CLAOBS
