                         T_FAMILIAS ON T_ARTICULOS.FAMILIA = T_FAMILIAS.FAMILIA AND T_ARTICULOS.CodEMP = T_FAMILIAS.CodEMP LEFT OUTER JOIN
                         T_CATEGORIAS ON T_ARTICULOS.CATEGORIA = T_CATEGORIAS.CATEGO AND T_ARTICULOS.CodEMP = T_CATEGORIAS.CODEMP
WHERE        (T_ARTICULOS.CodEMP = @empresa) AND (T_ARTICULOS.CODIGO LIKE @Parametro) AND (T_ARTICULOS.FAMILIA &lt;&gt; 'MP') AND (T_ARTICULOS.FAMILIA &lt;&gt; 'TO')</CommandText>
